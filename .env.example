# ============================================================================
# TempMail Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ---------- DATABASE ----------
POSTGRES_USER=tempmail
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=tempmail_db
DATABASE_URL=host=postgres user=tempmail password=CHANGE_ME_TO_A_STRONG_PASSWORD dbname=tempmail_db port=5432 sslmode=disable TimeZone=UTC

# ---------- REDIS ----------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ---------- SECURITY TOKENS ----------
# Internal service-to-service token (mail-edge → api)
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# External API key for the main web app to call SDK endpoints
EXTERNAL_API_KEY=CHANGE_ME_EXTERNAL_API_KEY

# Admin panel access key
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# Admin panel URL path (random = not guessable)
# If blank, a random path is generated each restart and printed to logs
ADMIN_PANEL_PATH=

# ---------- CLOUDFLARE R2 (Object Storage) ----------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=tempmail-archives

# ---------- SPAM FILTERING ----------
# Rspamd HTTP endpoint (container name)
RSPAMD_URL=http://rspamd:11333
RSPAMD_PASSWORD=
# Score above which emails are rejected outright
SPAM_REJECT_THRESHOLD=15

# ---------- FRONTEND (Optional) ----------
# CORS origin — only needed if browsers call this API directly via JavaScript.
# If your web app calls from server-side (Node.js/Go/PHP), leave blank or remove.
# FRONTEND_URL=https://yourdomain.com

# ---------- LOGGING ----------
LOG_LEVEL=info
LOG_MAX_AGE_DAYS=14
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=10

# ---------- SMTP ----------
# Max message size in MB
MAX_MESSAGE_SIZE_MB=25
# Max attachments per email (excess are dropped)
MAX_ATTACHMENTS=10
# Max single attachment size in MB (oversized are dropped)
MAX_ATTACHMENT_SIZE_MB=10
