# ============================================================================
# TempMail Platform — Environment Configuration
# ============================================================================
# Copy this file to .env:   cp .env.example .env
# Or use deploy.sh:         chmod +x deploy.sh && ./deploy.sh
# ============================================================================
#
# ⚠ Infrastructure-only config below.
#   Runtime settings (TTL, rate limits, spam threshold, etc.)
#   are managed from the Admin Panel → Settings tab.
#
#   API Keys are auto-generated on first boot and managed
#   from Admin Panel → API Keys tab.
#
# ============================================================================

# ---------- DATABASE ----------
POSTGRES_USER=tempmail
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=tempmail_db
DATABASE_URL=host=postgres user=tempmail password=CHANGE_ME_TO_A_STRONG_PASSWORD dbname=tempmail_db port=5432 sslmode=disable TimeZone=UTC

# ---------- REDIS ----------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ---------- SECURITY ----------
# API Keys are managed from Admin Panel → API Keys tab
# (auto-generated on first boot, printed to docker logs)
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
ADMIN_USERNAME=admin
ADMIN_PANEL_PATH=CHANGE_ME_TO_RANDOM_PATH

# ---------- CLOUDFLARE R2 ----------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=tempmail-archives

# ---------- SERVICE URLS ----------
RSPAMD_URL=http://rspamd:11333
RSPAMD_PASSWORD=

# ---------- FRONTEND (Optional) ----------
# FRONTEND_URL=https://yourdomain.com

# ---------- LOGGING ----------
LOG_FILE_PATH=stdout

# ---------- APPLICATION CONFIG (Optional — sane defaults) ----------
# All values below have sensible defaults. Only set if you need to override.
#
# TZ=Asia/Bangkok                  # Timezone (default: Asia/Bangkok)
# PORT=4000                        # API server port
# BODY_LIMIT_MB=40                 # HTTP body limit (MB)
# PUBLIC_RATE_LIMIT=60             # Public API rate limit (req/min)
# LOGIN_RATE_LIMIT=10              # Admin login rate limit (req/min)
# API_READ_TIMEOUT=30s             # HTTP read timeout
# API_WRITE_TIMEOUT=30s            # HTTP write timeout
# API_IDLE_TIMEOUT=120s            # HTTP idle timeout
# SMTP_PORT=2525                   # SMTP internal port
# SMTP_DOMAIN=tempmail.local       # SMTP server domain
# SMTP_MAX_MESSAGE_MB=25           # Max email size (MB)
# SMTP_MAX_RECIPIENTS=50           # Max recipients per email
# SMTP_RATE_LIMIT=50               # SMTP connections per IP/min
# RSPAMD_TIMEOUT=10s               # Rspamd scan timeout
# INGEST_TIMEOUT=30s               # Mail ingest API timeout
# WORKER_CONCURRENCY=10            # Background worker threads
# RETENTION_CRON=@hourly           # Message cleanup schedule
# MAILBOX_EXPIRE_CRON=*/5 * * * *  # Mailbox expiry schedule
